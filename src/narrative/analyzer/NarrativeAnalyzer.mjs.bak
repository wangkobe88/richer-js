    if (!result) {
      const fixedJsonStr = jsonStr.replace(/"/g, "'").replace(/"/g, "'");
      result = tryParseJSON(fixedJsonStr);
    }

    if (!result) {
      console.error('[NarrativeAnalyzer] JSON解析: 解析失败，提取的字符串:', jsonStr);
      throw new Error('JSON解析: 解析失败');
    }

    return result;
